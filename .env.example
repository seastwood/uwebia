# Copy to `.env` and fill in real values before `docker compose up`.
# `.env` is read automatically by docker-compose.

# ── Postgres ────────────────────────────────────────────────────────────
# The Postgres container is initialised with these credentials on first
# run; afterwards the same values are used to build the app's DATABASE_URL.
POSTGRES_USER=uwebia
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=uwebia

# ── Flask ───────────────────────────────────────────────────────────────
# Long random string. Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=replace-with-64-hex-chars

# ── Gunicorn (optional) ─────────────────────────────────────────────────
# GUNICORN_WORKERS=3
# GUNICORN_TIMEOUT=120

# ── App listener (when fronted by pfSense HAProxy / external proxy) ─────
# Host port pfSense HAProxy will forward to. Default 5772.
# APP_HOST_PORT=5772
# Set to 127.0.0.1 if the proxy is on the SAME host as docker and the
# port should NOT be reachable from the LAN. Default 0.0.0.0 (LAN-reachable).
# LISTEN_ADDR=127.0.0.1

# ── Caddy (only used with `--profile caddy`) ────────────────────────────
# Ignore these if HAProxy / Nginx / Cloudflare is fronting the app instead.
#   • Real domain → Caddy provisions a Let's Encrypt cert (set ACME_EMAIL).
#   • `:80`        → Caddy serves plain HTTP on port 80 (local testing).
# SITE_ADDRESS=:80
# ACME_EMAIL=
